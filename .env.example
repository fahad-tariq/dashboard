ADDR=:8080
IDEAS_PATH=/data/ideas.md
UPLOADS_DIR=/data/uploads
PERSONAL_PATH=/data/personal.md
FAMILY_PATH=/data/family.md
DB_PATH=/data/db/dashboard.db
DASHBOARD_API_TOKEN=change-me

# Auth (leave DASHBOARD_PASSWORD_HASH empty to disable auth)
# Generate hash: htpasswd -nbBC 10 "" 'your-password' | cut -d: -f2
DASHBOARD_PASSWORD_HASH=
SESSION_LIFETIME=720h
USER_DATA_DIR=/data/users
# Set to true when serving over HTTPS
DASHBOARD_SECURE_COOKIES=false
